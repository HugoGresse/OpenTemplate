{
  "name": "opentemplate",
  "version": "0.1.0",
  "description": "Image/PDF generation API from HTML+CSS templates. Satori primary, Puppeteer fallback.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "copy:monaco": "node scripts/copy-monaco.mjs",
    "postinstall": "node scripts/copy-monaco.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.0.3",
    "@resvg/resvg-js": "^2.6.2",
    "async-mutex": "^0.5.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "juice": "^11.0.0",
    "monaco-editor": "^0.52.2",
    "mustache": "^4.2.0",
    "nanoid": "^5.0.9",
    "puppeteer": "^24.15.0",
    "satori": "^0.12.1",
    "satori-html": "^0.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.5",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-plugin-security": "^3.0.1",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
